{
  "name": "miniprogram-ts-less-quickstart",
  "version": "2.0.6",
  "description": "这是一个家庭菜单预约小程序，用于记录每天早中晚餐的菜单，并且记录每一餐所需的食材和做法。用户可以创建、修改、删除和查询菜品，进行日历预约，并管理冰箱库存。",
  "scripts": {
    "build": "echo 构建完成",
    "worker:login": "npx --yes wrangler login",
    "worker:whoami": "npx --yes wrangler whoami",
    "worker:dry-run": "npx --yes wrangler deploy --dry-run --config cloudflareWorkes/wrangler.toml",
    "worker:deploy": "npx --yes wrangler deploy --config cloudflareWorkes/wrangler.toml",
    "miniprogram:upload": "node scripts/upload-miniprogram.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.7",
    "miniprogram-ci": "^2.0.7",
    "miniprogram-api-typings": "^2.8.3-1"
  },
  "main": ".eslintrc.js",
  "dependencies": {
    "@lspriv/wc-plugin-lunar": "^1.0.3-alpha.0",
    "@lspriv/wx-calendar": "^1.8.4",
    "cnchar": "^3.2.6",
    "cnchar-order": "^3.2.6",
    "cnchar-poly": "^3.2.6",
    "weui-miniprogram": "^1.2.4"
  }
}
