.container {
  background: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

/* ── 轮播图 ── */
.dish-swiper {
  width: 100%;
  height: 480rpx;
  background: #111;
}
.swiper-item { display: flex; }
.swiper-image {
  width: 100%;
  height: 100%;
  will-change: transform;
}

/* ── 图片编辑区 ── */
.image-edit-section {
  background: var(--card-bg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.image-item {
  width: 192rpx;
  height: 192rpx;
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.thumbnail { width: 100%; height: 100%; }
.image-delete {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.image-add {
  width: 192rpx;
  height: 192rpx;
  background: var(--input-bg);
  border: 2rpx dashed #C8C8C8;
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: var(--primary-color);
}
.add-icon { font-size: 52rpx; line-height: 1; font-weight: 200; }
.add-text { font-size: 22rpx; color: var(--text-light); }

/* ── 基本信息 ── */
.info-section {
  background: var(--card-bg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.dish-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dish-tag {
  font-size: 22rpx;
  padding: 5rpx 20rpx;
  border-radius: var(--radius-full);
  line-height: 1.6;
}
.dish-tag.type { background: var(--primary-light); color: var(--primary-dark); }
.dish-tag.spicy { background: var(--danger-light); color: var(--danger-color); }

/* ── 详情 Section ── */
.detail-section {
  background: var(--card-bg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
  margin-bottom: 20rpx;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

.section-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
.reference { color: #2196F3; }

/* ── 食材（查看模式） ── */
.ingredients-container { display: flex; flex-direction: column; }

.ingredient-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}
.ingredient-row:last-child { border-bottom: none; }

.ingredient-name {
  font-size: 28rpx;
  color: var(--text-color);
  flex: 1;
}

.ingredient-amount {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
}

/* 库存状态标签 */
.inv-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-left: 16rpx;
  flex-shrink: 0;
}
.inv-sufficient { background: var(--primary-light); color: var(--primary-dark); }
.inv-expiring { background: var(--warning-light); color: #E65100; }
.inv-expired { background: var(--danger-light); color: #C62828; }
.inv-missing { background: #F5F5F5; color: #9E9E9E; }

/* ── 制作步骤（查看模式） ── */
.steps-list { display: flex; flex-direction: column; gap: 20rpx; }

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  padding-top: 10rpx;
}

/* ── 底部固定区域 ── */
.bottom-fixed-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--card-bg);
  box-shadow: 0 -1rpx 0 var(--border-color);
  transform: translateZ(0);
}

.bottom-safe-area { height: 160rpx; }

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background: var(--card-bg);
}

/* ── 底部操作按钮 ── */
.action-buttons {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  transition: opacity 0.15s;
}
.action-btn:active { opacity: 0.8; }
.action-btn.edit, .action-btn.save {
  background: var(--primary-color);
  color: #fff;
}
.action-btn.delete {
  background: transparent;
  color: var(--danger-color);
  border: 2rpx solid var(--danger-color);
}
.action-btn.cancel {
  background: transparent;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

/* ── 编辑模式 ── */
.edit-item {
  margin-bottom: 24rpx;
}
.edit-item:last-child { margin-bottom: 0; }

.edit-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-color);
  transition: border-color 0.2s;
}
.edit-input:focus { border-color: var(--primary-color); }

.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-color);
  line-height: 1.6;
  transition: border-color 0.2s;
}
.edit-textarea:focus { border-color: var(--primary-color); }

.edit-picker {
  width: 100%;
  height: 88rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--text-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.edit-picker::after {
  content: '›';
  font-size: 36rpx;
  color: var(--text-light);
  transform: rotate(90deg);
  display: inline-block;
}

/* ── 编辑模式食材 ── */
.ingredients-edit-container { display: flex; flex-direction: column; gap: 16rpx; }

.ingredient-edit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ingredient-name-input {
  flex: 2;
  height: 80rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  transition: border-color 0.2s;
}
.ingredient-name-input:focus { border-color: var(--primary-color); }

.ingredient-amount-input {
  flex: 1;
  height: 80rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  transition: border-color 0.2s;
}
.ingredient-amount-input:focus { border-color: var(--primary-color); }

.ingredient-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--danger-color);
  flex-shrink: 0;
}

/* ── 编辑模式步骤 ── */
.steps-edit-list { display: flex; flex-direction: column; gap: 20rpx; }

.step-edit-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-content-input {
  flex: 1;
  min-height: 120rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.6;
  transition: border-color 0.2s;
}
.step-content-input:focus { border-color: var(--primary-color); }

.step-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--danger-color);
  margin-top: 8rpx;
}

.add-button {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-color);
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx dashed var(--primary-color);
  border-radius: var(--radius-sm);
  background: var(--primary-light);
  margin-top: 16rpx;
  transition: opacity 0.15s;
}
.add-button:active { opacity: 0.7; }