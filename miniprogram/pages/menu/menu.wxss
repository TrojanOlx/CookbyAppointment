.container {
  position: relative;
  height: 100vh;
  background: var(--background-color);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── Tab 类型选择器 ── */
.type-selector {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-bottom: 1rpx solid var(--border-color);
}

/* 固定"全部"项 */
.type-item.fixed {
  flex-shrink: 0;
  min-width: 104rpx;
  padding: 0 24rpx;
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.type-item.fixed::after {
  content: '';
  position: absolute;
  right: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 1rpx;
  background: var(--border-color);
}
.type-item.fixed.active {
  color: var(--primary-color);
  font-weight: 700;
}
.type-item.fixed.active::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

/* 可滚动区域 */
.scroll-types {
  flex: 1;
  height: 88rpx;
  white-space: nowrap;
}

.type-selector-content {
  display: inline-flex;
  height: 88rpx;
  align-items: stretch;
  padding-right: 24rpx;
}

/* 普通 type-item */
.type-item {
  min-width: 112rpx;
  height: 88rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-secondary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: color 0.2s;
}
.type-item:last-child {
  padding-right: 32rpx;
}
.type-item.active {
  color: var(--primary-color);
  font-weight: 700;
}
.type-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

/* ── 菜品列表 ── */
.dish-list {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  padding-top: calc(88rpx + 20rpx);
  height: calc(100vh - 88rpx);
}

.dish-item {
  display: flex;
  align-items: center;
  width: 100%;
  background: var(--card-bg);
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  transition: opacity 0.15s;
}
.dish-item:active { opacity: 0.8; }

.dish-image {
  width: 152rpx;
  height: 152rpx;
  min-width: 152rpx;
  border-radius: var(--radius-sm);
  margin-right: 24rpx;
  background: var(--input-bg);
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  gap: 12rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dish-tag {
  font-size: 22rpx;
  padding: 4rpx 18rpx;
  border-radius: var(--radius-full);
  line-height: 1.6;
}
.dish-tag.type {
  background: var(--primary-light);
  color: var(--primary-dark);
}
.dish-tag.spicy {
  background: var(--danger-light);
  color: var(--danger-color);
}

/* ── FAB ── */
.add-btn {
  position: fixed;
  right: 40rpx;
  width: 104rpx;
  height: 104rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 200;
  transition: transform 0.15s, box-shadow 0.15s;
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
.add-btn:active {
  transform: scale(0.93);
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.22);
}

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 16rpx;
}
.empty-text {
  font-size: 30rpx;
  color: var(--text-light);
}

/* ── 加载状态 ── */
.loading-container {
  padding: 24rpx 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.loading-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--text-light);
  font-size: 24rpx;
}
.loading-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.no-more-tip {
  color: var(--text-light);
  font-size: 24rpx;
  padding: 12rpx 0;
  text-align: center;
}
