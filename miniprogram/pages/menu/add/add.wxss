.container {
  padding: 24rpx;
  background: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

/* ── 表单区块 ── */
.form-section {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
  margin-bottom: 28rpx;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

/* ── 表单项 ── */
.form-item {
  margin-bottom: 28rpx;
}
.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.form-input {
  height: 88rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.form-input:focus { border-color: var(--primary-color); }

.form-textarea {
  min-height: 160rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
  line-height: 1.6;
  transition: border-color 0.2s;
}
.form-textarea:focus { border-color: var(--primary-color); }

/* ── Picker ── */
.picker {
  height: 88rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker::after {
  content: '›';
  font-size: 36rpx;
  color: var(--text-light);
  transform: rotate(90deg);
  display: inline-block;
}
.picker.placeholder { color: var(--text-light); }

/* ── 图片上传 ── */
.image-upload-area { margin-top: 8rpx; }

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 192rpx;
  height: 192rpx;
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.image-item image { width: 100%; height: 100%; }

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.upload-btn {
  width: 192rpx;
  height: 192rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #C8C8C8;
  border-radius: var(--radius-sm);
  color: var(--text-light);
  font-size: 24rpx;
  gap: 8rpx;
  background: var(--input-bg);
  transition: border-color 0.2s;
}
.upload-btn:active { border-color: var(--primary-color); }

.plus {
  font-size: 56rpx;
  line-height: 1;
  color: var(--primary-color);
  font-weight: 200;
}

/* ── 食材 ── */
.ingredients-list { display: flex; flex-direction: column; gap: 16rpx; }

.ingredient-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ingredient-name {
  flex: 2;
  height: 80rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  transition: border-color 0.2s;
}
.ingredient-name:focus { border-color: var(--primary-color); }

.ingredient-amount {
  flex: 1;
  height: 80rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  transition: border-color 0.2s;
}
.ingredient-amount:focus { border-color: var(--primary-color); }

.delete-ingredient {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--danger-color);
  font-size: 36rpx;
  flex-shrink: 0;
}

.add-ingredient {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: var(--primary-color);
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx dashed var(--primary-color);
  border-radius: var(--radius-sm);
  background: var(--primary-light);
  transition: opacity 0.15s;
}
.add-ingredient:active { opacity: 0.7; }

/* ── 步骤 ── */
.steps-list { display: flex; flex-direction: column; gap: 20rpx; }

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.step-content {
  flex: 1;
  min-height: 120rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.6;
  transition: border-color 0.2s;
}
.step-content:focus { border-color: var(--primary-color); }

.delete-step {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--danger-color);
  font-size: 36rpx;
  margin-top: 10rpx;
}

.add-step {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: var(--primary-color);
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx dashed var(--primary-color);
  border-radius: var(--radius-sm);
  background: var(--primary-light);
  transition: opacity 0.15s;
}
.add-step:active { opacity: 0.7; }

.inline-add-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.inline-add-icon::before,
.inline-add-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: var(--radius-full);
  transform: translate(-50%, -50%);
}

.inline-add-icon::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

/* ── 底部固定区域 ── */
.bottom-fixed-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--card-bg);
  box-shadow: 0 -1rpx 0 var(--border-color);
  transform: translateZ(0);
}

.bottom-safe-area { height: 160rpx; }

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background: var(--card-bg);
}

/* ── 按钮 ── */
.form-actions {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.cancel-btn:active { opacity: 0.7; }

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.submit-btn:active { opacity: 0.82; }