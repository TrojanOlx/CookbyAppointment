.container {
  min-height: 100vh;
  width: 100%;
  background: var(--background-color);
  padding: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* 页面头部 */
.page-header {
  width: 100%;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: var(--card-bg);
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.appointment-info {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
  text-align: center;
}

/* 菜品列表 */
.dishes-list {
  width: 100%;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.dish-card {
  width: 100%;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: border-color 0.2s, background 0.2s, transform 0.2s;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.dish-card.active {
  border-color: var(--primary-color);
  background: var(--primary-light);
  transform: translateY(-2rpx);
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.dish-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.dish-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  margin-right: 20rpx;
  background: var(--input-bg);
}

.dish-details {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 10rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
}

.dish-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.dish-tag.type {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.dish-tag.spicy {
  background: var(--danger-light);
  color: var(--danger-color);
}

.review-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.review-status .reviewed {
  color: var(--primary-dark);
  background: var(--primary-light);
  border: 1rpx solid rgba(76, 175, 80, 0.25);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.review-status .not-reviewed {
  color: var(--warning-color);
  background: var(--warning-light);
  border: 1rpx solid rgba(255, 152, 0, 0.25);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

/* 评价表单 */
.review-form {
  width: 100%;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 30rpx 24rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.form-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 30rpx;
  text-align: center;
  width: 100%;
}

.rating-section, .comment-section, .image-section {
  width: 100%;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.rating-title, .comment-title, .image-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
  width: 100%;
}

.comment-input {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  box-sizing: border-box;
  background: var(--input-bg);
}

.comment-input:focus {
  border-color: var(--primary-color);
}

.comment-counter {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 10rpx;
  width: 100%;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.image-item {
  width: 180rpx;
  height: 180rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 0 0 0 var(--radius-sm);
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #C8C8C8;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--input-bg);
  transition: border-color 0.2s ease;
}
.upload-btn:active { border-color: var(--primary-color); }

.upload-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
}

.upload-icon::before,
.upload-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 52rpx;
  height: 5rpx;
  background: var(--primary-color);
  border-radius: var(--radius-full);
  transform: translate(-50%, -50%);
}

.upload-icon::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.submit-btn {
  background: var(--primary-color);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border-radius: var(--radius-full);
  width: 100%;
  text-align: center;
  box-sizing: border-box;
}

.submit-btn[disabled] {
  background: #A5D6A7;
  color: #fff;
  opacity: 0.7;
}

/* 评价结果 */
.review-result {
  width: 100%;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 30rpx 24rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}

.result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--primary-dark);
  margin-bottom: 30rpx;
  text-align: center;
  width: 100%;
}

.result-rating {
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
  width: 100%;
}

.result-content {
  width: 100%;
  background: var(--input-bg);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  box-sizing: border-box;
}

.result-images {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.result-images image {
  width: 180rpx;
  height: 180rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-sm);
}

.result-time {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-light);
  text-align: right;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 空表单 */
.empty-form {
  width: 100%;
  padding: 60rpx 20rpx;
  text-align: center;
  color: var(--text-light);
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

/* 菜品部分 */
.dishes-section {
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 评价内容部分 */
.review-content {
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  margin-bottom: 30rpx;
} 