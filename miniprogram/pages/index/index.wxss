/**index.wxss**/
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background-color: #f6f6f6;
  position: relative;
  overflow: hidden;
}

/* 固定的导航部分 */
.fixed-header {
  width: 100%;
  background-color: #f6f6f6;
  padding: 0 30rpx;
  box-sizing: border-box;
  z-index: 10;
  position: relative;
}

/* 可滚动内容部分 */
.features-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 0 30rpx;
  overflow-x: hidden;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 50rpx;
  margin-bottom: 50rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 10rpx;
}

.app-desc {
  font-size: 30rpx;
  color: #999;
}

.features {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 20rpx;
}

.feature-item {
  width: 90%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s;
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.menu-icon {
  color: #FF9800;
}

.calendar-icon {
  color: #2196F3;
}

.fridge-icon {
  color: #9C27B0;
}

.feature-name {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
  color: #333;
}

.feature-desc {
  font-size: 28rpx;
  color: #666;
}

.footer {
  width: 100%;
  padding: 20rpx 0;
  display: flex;
  justify-content: center;
  margin-bottom: calc(50rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(48px + env(safe-area-inset-bottom)); /* 基础TabBar高度 + 安全区域 */
}

.version {
  font-size: 24rpx;
  color: #999;
}

/* 快捷导航宫格 */
.nav-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 10rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.nav-item:active { opacity: 0.7; }
.nav-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}
.nav-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 信息卡片通用 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.section-date {
  font-size: 24rpx;
  color: #999;
}
.section-more {
  font-size: 24rpx;
  color: #4CAF50;
}
.section-body { width: 100%; }
.loading-hint {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 20rpx 0;
}
.empty-hint { padding: 10rpx 0; }
.empty-hint-text { font-size: 26rpx; color: #bbb; }

/* 今日预约行 */
.appt-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.appt-row:last-child { border-bottom: none; }
.appt-meal-badge {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
  margin-right: 16rpx;
  font-weight: 500;
}
.meal-breakfast { background: #FF9800; }
.meal-lunch { background: #4CAF50; }
.meal-dinner { background: #2196F3; }
.appt-dish-count {
  font-size: 26rpx;
  color: #555;
  flex: 1;
}
.appt-status {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.status-pending  { background: #FFF3E0; color: #E65100; }
.status-confirmed { background: #E8F5E9; color: #2E7D32; }
.status-completed { background: #E3F2FD; color: #1565C0; }
.status-cancelled { background: #F5F5F5; color: #9E9E9E; }

/* 库存告警卡片 */
.warn-card { border-left: 6rpx solid #FF9800; }
.expiry-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.expiry-row:last-child { border-bottom: none; }
.expiry-name { font-size: 28rpx; color: #333; flex: 1; }
.expiry-amount { font-size: 24rpx; color: #888; margin-right: 16rpx; }
.expiry-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.tag-expiring { background: #FFF3E0; color: #E65100; }
.tag-expired  { background: #FFEBEE; color: #C62828; }
