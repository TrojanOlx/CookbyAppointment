/**index.wxss**/
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: var(--background-color);
  position: relative;
  overflow: hidden;
}

/* 固定的导航部分 */
.fixed-header {
  width: 100%;
  background: var(--background-color);
  padding: 0 24rpx;
  box-sizing: border-box;
  z-index: 10;
  position: relative;
}

/* 可滚动内容部分 */
.features-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
  overflow-x: hidden;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 50rpx;
  margin-bottom: 50rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 10rpx;
}

.app-desc {
  font-size: 30rpx;
  color: var(--text-light);
}

.features {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 20rpx;
}

.feature-item {
  width: 90%;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 25rpx;
  margin-bottom: 25rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
  transition: transform 0.3s;
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.menu-icon {
  color: #FF9800;
}

.calendar-icon {
  color: #2196F3;
}

.fridge-icon {
  color: #9C27B0;
}

.feature-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  color: var(--text-color);
}

.feature-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 快捷导航宫格 */
.nav-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 30rpx 10rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.nav-item:active { opacity: 0.7; }
.nav-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}
.nav-label {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

/* 信息卡片通用 */
.section-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}
.section-date {
  font-size: 24rpx;
  color: var(--text-light);
}
.section-more {
  font-size: 24rpx;
  color: var(--primary-color);
}
.section-body { width: 100%; }
.loading-hint {
  text-align: center;
  color: var(--text-light);
  font-size: 26rpx;
  padding: 20rpx 0;
}
.empty-hint { padding: 10rpx 0; }
.empty-hint-text { font-size: 26rpx; color: var(--text-light); }

/* 今日预约行 */
.appt-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}
.appt-row:last-child { border-bottom: none; }
.appt-meal-badge {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  color: #fff;
  margin-right: 16rpx;
  font-weight: 500;
}
.meal-breakfast { background: #FF9800; }
.meal-lunch { background: #4CAF50; }
.meal-dinner { background: #2196F3; }
.appt-dish-count {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
}
.appt-status {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}
.status-pending  { background: #FFF3E0; color: #E65100; }
.status-confirmed { background: #E8F5E9; color: #2E7D32; }
.status-completed { background: #E3F2FD; color: #1565C0; }
.status-cancelled { background: #F5F5F5; color: #9E9E9E; }

/* 库存告警卡片 */
.warn-card { border-left: 6rpx solid #FF9800; }
.expiry-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}
.expiry-row:last-child { border-bottom: none; }
.expiry-name { font-size: 28rpx; color: var(--text-color); flex: 1; }
.expiry-amount { font-size: 24rpx; color: var(--text-light); margin-right: 16rpx; }
.expiry-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}
.tag-expiring { background: #FFF3E0; color: #E65100; }
.tag-expired  { background: #FFEBEE; color: #C62828; }

/* ── 无预约 empty-state 卡 ─────────────────────────────── */
.empty-day-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 28rpx 28rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.empty-day-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
}
.empty-day-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 12rpx;
}
.empty-day-sub {
  font-size: 26rpx;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}
.empty-day-btn {
  background: var(--primary-color);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 64rpx;
  border-radius: var(--radius-full);
  letter-spacing: 2rpx;
  box-shadow: var(--shadow-fab);
}
.empty-day-btn:active { opacity: 0.85; }

/* ── CSS 碗 & 餐具插图（empty-day） ───────────────────── */
.illus-wrap {
  position: relative;
  width: 180rpx;
  height: 140rpx;
  margin-bottom: 28rpx;
}
.illus-plate {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 130rpx;
  height: 70rpx;
  background: #E8F5E9;
  border-radius: 50% 50% 50% 50% / 30% 30% 70% 70%;
  border: 3rpx solid #A5D6A7;
  display: flex;
  align-items: center;
  justify-content: center;
}
.illus-bowl-inner {
  width: 80rpx;
  height: 36rpx;
  background: #C8E6C9;
  border-radius: 50%;
}
.illus-steam {
  position: absolute;
  width: 6rpx;
  border-radius: 6rpx;
  background: #A5D6A7;
  animation: steam 2s ease-in-out infinite;
}
.s1 { height: 30rpx; left: 52rpx;  bottom: 68rpx; animation-delay: 0s; }
.s2 { height: 40rpx; left: 69rpx;  bottom: 74rpx; animation-delay: 0.3s; }
.s3 { height: 28rpx; left: 86rpx;  bottom: 66rpx; animation-delay: 0.6s; }
@keyframes steam {
  0%,100% { opacity: 0.4; transform: translateY(0) scaleX(1); }
  50%      { opacity: 1;   transform: translateY(-10rpx) scaleX(1.3); }
}
.illus-fork {
  position: absolute;
  left: 10rpx;
  bottom: 4rpx;
  width: 8rpx;
  height: 80rpx;
  background: #81C784;
  border-radius: 4rpx;
}
.illus-fork::before {
  content: '';
  position: absolute;
  top: 0; left: -6rpx;
  width: 6rpx; height: 28rpx;
  background: #81C784;
  border-radius: 3rpx;
}
.illus-fork::after {
  content: '';
  position: absolute;
  top: 0; left: 8rpx;
  width: 6rpx; height: 28rpx;
  background: #81C784;
  border-radius: 3rpx;
}
.illus-spoon {
  position: absolute;
  right: 10rpx;
  bottom: 4rpx;
  width: 8rpx;
  height: 80rpx;
  background: #81C784;
  border-radius: 4rpx;
}
.illus-spoon::before {
  content: '';
  position: absolute;
  top: -6rpx; left: -10rpx;
  width: 28rpx; height: 28rpx;
  background: #81C784;
  border-radius: 50%;
}

/* ── 未登录：欢迎主卡 ─────────────────────────────────── */
.welcome-hero {
  background: linear-gradient(145deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: var(--radius-lg);
  padding: 44rpx 36rpx 48rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-md);
}
.welcome-illus-wrap {
  position: relative;
  width: 200rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}
/* 复用碗插图，稍大 */
.wh-plate {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 150rpx;
  height: 80rpx;
  background: var(--card-bg);
  border-radius: 50% 50% 50% 50% / 30% 30% 70% 70%;
  border: 4rpx solid #A5D6A7;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wh-bowl-inner {
  width: 96rpx;
  height: 44rpx;
  background: #C8E6C9;
  border-radius: 50%;
}
.wh-steam {
  position: absolute;
  width: 7rpx;
  border-radius: 6rpx;
  background: #66BB6A;
  animation: steam 2s ease-in-out infinite;
}
.ws1 { height: 36rpx; left: 60rpx;  bottom: 80rpx; animation-delay: 0s; }
.ws2 { height: 48rpx; left: 80rpx;  bottom: 88rpx; animation-delay: 0.25s; }
.ws3 { height: 32rpx; left: 100rpx; bottom: 78rpx; animation-delay: 0.5s; }
.wh-fork {
  position: absolute;
  left: 12rpx;
  bottom: 4rpx;
  width: 9rpx;
  height: 96rpx;
  background: #66BB6A;
  border-radius: 5rpx;
}
.wh-fork::before {
  content: '';
  position: absolute;
  top: 0; left: -7rpx;
  width: 7rpx; height: 34rpx;
  background: #66BB6A;
  border-radius: 4rpx;
}
.wh-fork::after {
  content: '';
  position: absolute;
  top: 0; left: 10rpx;
  width: 7rpx; height: 34rpx;
  background: #66BB6A;
  border-radius: 4rpx;
}
.wh-spoon {
  position: absolute;
  right: 12rpx;
  bottom: 4rpx;
  width: 9rpx;
  height: 96rpx;
  background: #66BB6A;
  border-radius: 5rpx;
}
.wh-spoon::before {
  content: '';
  position: absolute;
  top: -8rpx; left: -12rpx;
  width: 32rpx; height: 32rpx;
  background: #66BB6A;
  border-radius: 50%;
}
.welcome-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-dark);
  margin-bottom: 12rpx;
  text-align: center;
}
.welcome-sub {
  font-size: 26rpx;
  color: var(--primary-color);
  text-align: center;
  margin-bottom: 40rpx;
  letter-spacing: 1rpx;
}
.welcome-login-btn {
  background: var(--primary-color);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 22rpx 80rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-fab);
  letter-spacing: 2rpx;
}
.welcome-login-btn:active { opacity: 0.85; }

/* ── 功能亮点卡列表 ───────────────────────────────────── */
.feature-cards {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}
.feat-card {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.feat-card:last-child { border-bottom: none; }
.feat-card:active { background: var(--input-bg); }
.feat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.green-bg  { background: #E8F5E9; }
.blue-bg   { background: #E3F2FD; }
.purple-bg { background: #F3E5F5; }
.feat-emoji { font-size: 40rpx; }
.feat-text-wrap { flex: 1; }
.feat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 6rpx;
  display: block;
}
.feat-desc {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
}
.feat-arrow {
  font-size: 36rpx;
  color: var(--border-color);
  margin-left: 8rpx;
}
