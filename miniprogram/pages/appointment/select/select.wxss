.page-container {
  position: relative;
  width: 100%;
  height: 100vh;
  background: var(--background-color);
  overflow: hidden;
}

/* ── 固定顶部 ── */
.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background: var(--background-color);
}

/* ── 头部 ── */
.header {
  width: 100%;
  background: var(--card-bg);
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--border-color);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  text-align: center;
}

/* ── 餐次选择 ── */
.meal-section {
  width: 100%;
  background: var(--card-bg);
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--border-color);
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}

.meal-types {
  display: flex;
  gap: 12rpx;
  width: 100%;
}

.meal-type-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--input-bg);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.meal-type-item.active {
  background: var(--primary-light);
  color: var(--primary-dark);
  border-color: var(--primary-color);
  font-weight: 700;
}

/* ── 筛选区域 ── */
.filter-section {
  width: 100%;
  background: var(--card-bg);
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--border-color);
}

.search-box {
  position: relative;
  margin-bottom: 14rpx;
  width: 100%;
}

.search-input {
  height: 72rpx;
  width: 100%;
  background: var(--input-bg);
  border-radius: var(--radius-full);
  padding: 0 72rpx 0 36rpx;
  font-size: 28rpx;
  color: var(--text-color);
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid var(--text-light);
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: '';
  position: absolute;
  right: -10rpx;
  bottom: -8rpx;
  width: 14rpx;
  height: 4rpx;
  background: var(--text-light);
  border-radius: var(--radius-full);
  transform: rotate(45deg);
}

.filter-tags {
  display: flex;
  align-items: center;
  width: 100%;
}

.filter-tag.fixed {
  flex-shrink: 0;
  position: relative;
  margin-right: 16rpx;
  padding-right: 16rpx;
}
.filter-tag.fixed::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 2rpx;
  height: 24rpx;
  background: var(--border-color);
}

.scroll-tags {
  flex: 1;
  white-space: nowrap;
}

.scroll-tags-content {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 16rpx;
}

.filter-tag {
  padding: 8rpx 24rpx;
  background: var(--input-bg);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-secondary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  transition: all 0.2s;
}
.filter-tag.active {
  background: var(--primary-color);
  color: #fff;
  font-weight: 600;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.clear-filter {
  font-size: 24rpx;
  color: var(--primary-color);
  padding: 6rpx 18rpx;
  border: 1rpx solid var(--primary-color);
  border-radius: var(--radius-full);
}

/* ── 底部固定区域 ── */
.bottom-fixed-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--card-bg);
  box-shadow: 0 -1rpx 0 var(--border-color);
  transform: translateZ(0);
}

/* 已选计数条 */
.selected-count-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--primary-light);
  padding: 12rpx 28rpx;
  border-top: 1rpx solid rgba(76,175,80,0.2);
}

.selected-count {
  font-size: 26rpx;
  color: var(--primary-dark);
  font-weight: 500;
}
.count-num {
  font-weight: 700;
  font-size: 30rpx;
  color: var(--primary-color);
}

.clear-selection {
  font-size: 24rpx;
  color: var(--danger-color);
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--danger-color);
  border-radius: var(--radius-full);
  background: #fff;
}

/* 底部按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  background: var(--card-bg);
  width: 100%;
  box-sizing: border-box;
}

.button-wrapper {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 32rpx;
  box-sizing: border-box;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background: var(--card-bg);
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-color);
  transition: opacity 0.15s;
}
.cancel-btn:active { opacity: 0.7; }

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  transition: opacity 0.15s;
}
.submit-btn:active { opacity: 0.82; }
.submit-btn[disabled] { background: #A5D6A7; opacity: 0.7; }

/* ── 滚动列表 ── */
.scroll-content {
  position: relative;
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.dish-list {
  padding: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.dish-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: var(--radius-md);
  position: relative;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid transparent;
  transition: border-color 0.2s, background 0.2s;
  box-sizing: border-box;
}
.dish-item.selected {
  background: var(--primary-light) !important;
  border-color: var(--primary-color) !important;
}

.dish-item .dish-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--text-color);
}
.dish-item.selected .dish-name { color: var(--primary-dark) !important; font-weight: 600; }
.dish-item.selected .dish-info { color: var(--primary-dark); }

.dish-item .check-icon {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  transform: scale(0);
  transition: transform 0.25s ease;
  z-index: 1;
}
.dish-item.selected .check-icon { transform: scale(1); }

.dish-image {
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--radius-sm);
  margin-right: 16rpx;
  background: var(--input-bg);
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}
.dish-tag.type { background: var(--primary-light); color: var(--primary-dark); }
.dish-tag.spicy { background: var(--danger-light); color: var(--danger-color); }

/* ── 加载 ── */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 16rpx;
  width: 100%;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #E8E8E8;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-spinner.small {
  width: 36rpx;
  height: 36rpx;
  border-width: 4rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text { font-size: 26rpx; color: var(--text-light); }

/* ── 空状态 ── */
.empty-tip {
  padding: 60rpx 0;
  text-align: center;
  width: 100%;
}
.empty-text { color: var(--text-light); font-size: 28rpx; }

.load-more-tip, .no-more-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  color: var(--text-light);
  font-size: 24rpx;
}