.container {
  position: relative;
  min-height: 100vh;
  width: 100%;
  background: var(--background-color);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(48px + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

/* ── 日历卡片 ── */
.calendar-section {
  width: 100%;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  background: var(--background-color);
}

.calendar-section calendar {
  --wc-primary-color: #4CAF50;
  --wc-primary-color-opacity: rgba(76,175,80,0.1);
  --wc-text-color: #1A1A1A;
  --wc-text-color-second: #555555;
  --wc-text-color-disabled: #CCCCCC;
  --wc-bg-color: #ffffff;
  --wc-bg-color-hover: #F5F5F7;
  --wc-border-color: #EBEBEB;
  --wc-holiday-color: #F56C6C;
  --wc-lunar-color: #999;
  --wc-lunar-size: 20rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

/* ── 预约列表区域 ── */
.appointments-section {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 0 20rpx 20rpx;
  overflow-x: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

.add-btn-mini {
  display: flex;
  align-items: center;
  background: var(--primary-color);
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  gap: 6rpx;
  transition: opacity 0.15s;
}
.add-btn-mini:active { opacity: 0.8; }

.add-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}
.add-icon::before,
.add-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 4rpx;
  background: #fff;
  border-radius: var(--radius-full);
  transform: translate(-50%, -50%);
}
.add-icon::after { transform: translate(-50%, -50%) rotate(90deg); }
.add-text { color: #fff; font-size: 26rpx; font-weight: 500; }

/* ── 预约列表 ── */
.appointments-list { width: 100%; overflow-x: hidden; }

/* ── 餐次卡片 ── */
.meal-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.meal-info { display: flex; align-items: center; gap: 12rpx; }

.meal-type {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
}

.dish-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--input-bg);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}

.meal-actions { display: flex; gap: 12rpx; }

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.action-btn:active { opacity: 0.75; }

.action-btn.edit {
  background: var(--primary-light);
  color: var(--primary-dark);
  border: 1rpx solid rgba(76,175,80,0.25);
}
.action-btn.delete {
  background: var(--danger-light);
  color: var(--danger-color);
  border: 1rpx solid rgba(244,67,54,0.25);
}
.action-btn.review {
  background: #FFF8E1;
  color: #E65100;
  border: 1rpx solid rgba(230,81,0,0.2);
}
.action-btn.reactivate {
  background: #ECEFF1;
  color: #546E7A;
  border: 1rpx solid rgba(84,110,122,0.25);
}

/* ── 菜品横向列表 ── */
.dishes-list {
  display: flex;
  white-space: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  width: 100%;
  padding-bottom: 4rpx;
}

.dish-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  width: 148rpx;
  flex-shrink: 0;
}

.dish-image {
  width: 148rpx;
  height: 148rpx;
  border-radius: var(--radius-sm);
  background: var(--input-bg);
  margin-bottom: 10rpx;
}

.dish-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 100%;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; color: #D0D0D0; }
.empty-text { font-size: 30rpx; color: var(--text-light); }
.empty-btn {
  background: var(--primary-color);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  margin-top: 8rpx;
  transition: opacity 0.15s;
}
.empty-btn:active { opacity: 0.82; }

/* ── 加载状态 ── */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid #E8E8E8;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text { font-size: 26rpx; color: var(--text-light); }

@keyframes spin { to { transform: rotate(360deg); } }

/* ── 状态 Badge ── */
.appointment-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-left: 16rpx;
  font-weight: 500;
}
.appointment-status.status-pending {
  color: var(--warning-color);
  background: var(--warning-light);
  border: 1rpx solid rgba(255,152,0,0.25);
}
.appointment-status.status-confirmed {
  color: #2196F3;
  background: rgba(33,150,243,0.1);
  border: 1rpx solid rgba(33,150,243,0.25);
}
.appointment-status.status-completed {
  color: var(--primary-dark);
  background: var(--primary-light);
  border: 1rpx solid rgba(76,175,80,0.25);
}
.appointment-status.status-cancelled {
  color: var(--danger-color);
  background: var(--danger-light);
  border: 1rpx solid rgba(244,67,54,0.25);
}
