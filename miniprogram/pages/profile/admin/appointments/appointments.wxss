.appointments-container { display: none; }

/* ── 主容器 ── */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--background-color);
}

/* ── 日历区域 ── */
.calendar-section {
  background: var(--card-bg);
  padding: 16rpx 20rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
}

/* ── 预约列表区域 ── */
.appointments-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

.appointments-list {
  flex: 1;
  overflow-y: auto;
  width: 100%;
}

/* ── 加载状态 ── */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #E8E8E8;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-text { font-size: 26rpx; color: var(--text-light); }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── 用户卡片 ── */
.user-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--border-color);
}

.user-header {
  padding: 22rpx 28rpx;
  background: var(--primary-light);
  border-bottom: 1rpx solid rgba(76,175,80,0.18);
  width: 100%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: opacity 0.15s;
}
.user-header:active { opacity: 0.8; }

.expand-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  transition: transform 0.25s;
}
.expand-icon.expanded { transform: rotate(180deg); }
.expand-icon .iconfont { font-size: 24rpx; color: var(--primary-dark); }

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-dark);
  padding-left: 18rpx;
  position: relative;
}
.user-name::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 28rpx;
  width: 6rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

/* ── 餐次列表 ── */
.meals-list {
  width: 100%;
  box-sizing: border-box;
  background: var(--card-bg);
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.25s ease, padding 0.3s ease;
  will-change: max-height, opacity;
}
.meals-list.expanded {
  padding: 16rpx 28rpx;
  opacity: 1;
  max-height: 4000rpx;
}
.meals-list.collapsed {
  padding: 0 28rpx;
  max-height: 0;
  opacity: 0;
}

.meal-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}
.meal-item:last-child { border-bottom: none; }

.meal-type-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--input-bg);
  border-left: 4rpx solid var(--primary-color);
}
.meal-item:nth-child(3n+2) .meal-type-wrapper { border-left-color: #FF9800; }
.meal-item:nth-child(3n+3) .meal-type-wrapper { border-left-color: #9C27B0; }

.meal-type {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.meal-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
  display: inline-block;
  vertical-align: middle;
}

.dish-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 12rpx 0;
}

.dish-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--input-bg);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-color);
}

/* ── 状态 badge ── */
.meal-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.status-pending { color: var(--warning-color); background: var(--warning-light); border: 1rpx solid rgba(255,152,0,0.25); }
.status-confirmed { color: #2196F3; background: rgba(33,150,243,0.1); border: 1rpx solid rgba(33,150,243,0.25); }
.status-completed { color: var(--primary-dark); background: var(--primary-light); border: 1rpx solid rgba(76,175,80,0.25); }
.status-cancelled { color: var(--danger-color); background: var(--danger-light); border: 1rpx solid rgba(244,67,54,0.25); }

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-text { font-size: 28rpx; color: var(--text-light); text-align: center; }

/* ── 操作按钮 ── */
.action-buttons {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}
.action-btn {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  transition: opacity 0.15s;
}
.action-btn:active { opacity: 0.75; }

.confirm-btn { background: rgba(33,150,243,0.12); color: #2196F3; border: 1rpx solid rgba(33,150,243,0.25); }
.complete-btn { background: var(--primary-light); color: var(--primary-dark); border: 1rpx solid rgba(76,175,80,0.25); }
.cancel-btn { background: var(--danger-light); color: var(--danger-color); border: 1rpx solid rgba(244,67,54,0.25); }
.review-btn { background: #FFF8E1; color: #E65100; border: 1rpx solid rgba(230,81,0,0.2); }
.reactivate-btn { background: #ECEFF1; color: #546E7A; border: 1rpx solid rgba(84,110,122,0.25); }