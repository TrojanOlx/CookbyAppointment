/* pages/profile/admin/reviews/reviews.wxss */
.container {
  min-height: 100vh;
  background: #f6f6f6;
  padding: 0 0 40rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  background: #fff;
  padding: 20rpx 24rpx;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.filter-label { font-size: 26rpx; color: #555; }
.filter-chip {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  background: #f0f0f0;
  color: #666;
}
.chip-active {
  background: #FFF3E0;
  color: #E65100;
  font-weight: 600;
}
.total-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
}

/* 评价卡片 */
.review-card {
  background: #fff;
  margin: 0 16rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}
.dish-thumb {
  width: 90rpx;
  height: 90rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}
.card-meta {
  flex: 1;
  padding: 0 16rpx;
}
.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  display: block;
  margin-bottom: 8rpx;
}
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #eee;
}
.user-name { font-size: 24rpx; color: #666; }
.bottom-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.stars-row { display: flex; flex-direction: row; }
.star { font-size: 26rpx; margin-right: 2rpx; }
.star-filled { color: #FFB300; }
.star-empty  { color: #E0E0E0; }
.meta-date { font-size: 22rpx; color: #aaa; }

.right-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}
.create-time { font-size: 22rpx; color: #ccc; }
.delete-btn {
  font-size: 24rpx;
  color: #fff;
  background: #f44336;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

/* 展开内容 */
.card-body {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f5f5f5;
}
.content-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  margin-bottom: 14rpx;
}
.empty-content { color: #bbb; }
.images-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}
.review-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
}

/* 列表尾部 */
.list-footer { text-align: center; padding: 20rpx 0 40rpx; }
.loading-tip, .no-more { font-size: 24rpx; color: #bbb; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #888; }
.loading-full { text-align: center; padding-top: 120rpx; font-size: 28rpx; color: #bbb; }