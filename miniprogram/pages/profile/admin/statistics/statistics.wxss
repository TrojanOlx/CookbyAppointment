.container {
  height: 100vh;
  background: var(--background-color);
}

/* ── 时间范围 Tab ── */
.range-tabs {
  display: flex;
  flex-direction: row;
  background: var(--card-bg);
  padding: 16rpx 24rpx;
  gap: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.range-tab {
  padding: 10rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--input-bg);
  transition: all 0.2s;
}
.tab-active {
  background: var(--primary-color);
  color: #fff;
  font-weight: 600;
}

/* ── 汇总网格 ── */
.summary-grid {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 0 16rpx 16rpx;
}
.summary-item {
  flex: 1;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 28rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}
.summary-item.green .summary-num { color: var(--primary-dark); }
.summary-item.orange .summary-num { color: #FB8C00; }
.summary-item.red .summary-num { color: var(--danger-color); }

.summary-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-color);
  line-height: 1.2;
}
.summary-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

/* ── 通用 Section 卡片 ── */
.section-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
  margin-bottom: 20rpx;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

/* ── Canvas 柱状图 ── */
.chart-wrap { width: 100%; height: 260rpx; }
.bar-canvas { width: 100%; height: 260rpx; display: block; }
.chart-empty {
  text-align: center;
  color: var(--text-light);
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* ── 餐次分布 ── */
.meal-list { width: 100%; }
.meal-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}
.meal-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.meal-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  width: 72rpx;
  flex-shrink: 0;
}
.progress-track {
  flex: 1;
  height: 12rpx;
  background: var(--input-bg);
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 16rpx;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  min-width: 4rpx;
  transition: width 0.4s;
}
.meal-count {
  font-size: 22rpx;
  color: var(--text-light);
  width: 140rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ── 排行榜 ── */
.rank-list { width: 100%; }
.rank-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}
.rank-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  margin-right: 12rpx;
  background: #B0BEC5;
}
.rank-1 { background: #FFB300; }
.rank-2 { background: #90A4AE; }
.rank-3 { background: #A1887F; }
.rank-other { background: var(--input-bg); color: var(--text-light); }

.rank-img, .user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  margin-right: 12rpx;
  background: var(--input-bg);
}
.user-avatar { border-radius: 50%; }

.rank-name {
  font-size: 26rpx;
  color: var(--text-color);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rank-bar-wrap {
  width: 160rpx;
  height: 10rpx;
  background: var(--input-bg);
  border-radius: 5rpx;
  overflow: hidden;
  margin: 0 12rpx;
  flex-shrink: 0;
}
.rank-bar {
  height: 100%;
  background: var(--primary-color);
  border-radius: 5rpx;
  min-width: 4rpx;
}
.user-bar { background: #2196F3; }

.rank-count {
  font-size: 22rpx;
  color: var(--text-light);
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.footer-pad { height: 60rpx; }