/* pages/profile/admin/statistics/statistics.wxss */
.container {
  height: 100vh;
  background: #f6f6f6;
}

/* 时间范围切换 */
.range-tabs {
  display: flex;
  flex-direction: row;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.range-tab {
  padding: 10rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}
.tab-active {
  background: #4CAF50;
  color: #fff;
  font-weight: 600;
}

/* 汇总卡片 */
.summary-grid {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 0 16rpx 16rpx;
}
.summary-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.summary-item.green .summary-num { color: #43A047; }
.summary-item.orange .summary-num { color: #FB8C00; }
.summary-item.red .summary-num { color: #E53935; }
.summary-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.2;
}
.summary-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* Canvas 柱状图 */
.chart-wrap {
  width: 100%;
  height: 260rpx;
}
.bar-canvas {
  width: 100%;
  height: 260rpx;
  display: block;
}
.chart-empty {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* 餐次分布 */
.meal-list { width: 100%; }
.meal-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}
.meal-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.meal-label {
  font-size: 26rpx;
  color: #444;
  width: 72rpx;
  flex-shrink: 0;
}
.progress-track {
  flex: 1;
  height: 14rpx;
  background: #f0f0f0;
  border-radius: 7rpx;
  overflow: hidden;
  margin: 0 16rpx;
}
.progress-fill {
  height: 100%;
  border-radius: 7rpx;
  min-width: 4rpx;
  transition: width 0.4s;
}
.meal-count {
  font-size: 22rpx;
  color: #888;
  width: 140rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 排行榜 */
.rank-list { width: 100%; }
.rank-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}
.rank-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  margin-right: 12rpx;
  background: #bbb;
}
.rank-1 { background: #FFB300; }
.rank-2 { background: #90A4AE; }
.rank-3 { background: #A1887F; }
.rank-other { background: #e0e0e0; color: #888; }
.rank-img, .user-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
  background: #f0f0f0;
}
.user-avatar { border-radius: 50%; }
.rank-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rank-bar-wrap {
  width: 160rpx;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 12rpx;
  flex-shrink: 0;
}
.rank-bar {
  height: 100%;
  background: #4CAF50;
  border-radius: 6rpx;
  min-width: 4rpx;
}
.user-bar { background: #2196F3; }
.rank-count {
  font-size: 22rpx;
  color: #888;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.footer-pad { height: 60rpx; }