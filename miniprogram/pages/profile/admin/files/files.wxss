/* 文件管理页面样式 */
.container {
  min-height: 100vh;
  padding: 24rpx;
  background: var(--background-color);
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 20rpx 0;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

/* 文件夹选择器 */
.folder-selector {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.folder-list {
  display: flex;
  white-space: nowrap;
}

.folder-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  background: var(--input-bg);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-secondary);
}

.folder-item.active {
  background: var(--primary-color);
  color: #fff;
  font-weight: 600;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.action-btn {
  margin: 0 !important;
  border-radius: var(--radius-full) !important;
  font-size: 24rpx !important;
}

/* 文件列表 */
.file-list {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.loading, .empty-list {
  padding: 60rpx 0;
  text-align: center;
  color: var(--text-light);
  font-size: 28rpx;
}

.files-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300rpx, 1fr));
  gap: 16rpx;
}

.file-item {
  position: relative;
  padding: 20rpx;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-sm);
  transition: border-color 0.2s, background 0.2s;
  border: 2rpx solid transparent;
}

.file-item.selected {
  background: var(--primary-light);
  border-color: var(--primary-color);
}

.file-icon {
  width: 100%;
  height: 160rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 10rpx;
  background: var(--input-bg);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.file-thumbnail {
  width: 100%;
  height: 100%;
}

.file-type-icon {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  color: var(--text-secondary);
}

.file-info {
  padding: 10rpx 0;
}

.file-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 6rpx;
}

.file-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: var(--text-light);
}

.ellipsis {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.file-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.action-icon {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 28rpx;
  margin-left: 10rpx;
  border-radius: 50%;
  background: var(--input-bg);
}

.action-icon.delete {
  color: var(--danger-color);
}

/* 文件信息弹窗 */
.file-info-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-content {
  width: 100%;
  max-width: 600rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  box-shadow: var(--shadow-lg);
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
}

.modal-close {
  font-size: 48rpx;
  color: var(--text-light);
  line-height: 1;
}

.modal-body {
  margin-top: 20rpx;
}

.info-item {
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-right: 10rpx;
  font-weight: 600;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-color);
  word-break: break-all;
}

.info-url {
  color: var(--primary-color);
  text-decoration: underline;
} 