/* 页面容器 */
.profile-container {
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); /* 为TabBar留出足够空间 */
  background: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 用户信息区域 */
.user-info {
  background: linear-gradient(145deg, var(--primary-light) 0%, var(--card-bg) 100%);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: var(--shadow-md);
}

.login-btn {
  width: 70%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: var(--radius-full);
  margin: 20rpx 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: var(--shadow-fab);
}

.login-options-btn {
  width: 45%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2196F3;
  color: #fff;
  border-radius: var(--radius-full);
  margin: 20rpx 10rpx;
  font-size: 30rpx;
}

.get-info-btn {
  font-size: 26rpx;
  color: #2196F3;
  padding: 10rpx 0;
  margin-top: 10rpx;
  text-decoration: underline;
}

.userinfo-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2196F3;
  color: #fff;
  border-radius: var(--radius-full);
  margin: 20rpx auto;
  font-size: 30rpx;
}

.user-avatar-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 30rpx;
  border: 4rpx solid var(--primary-color);
  box-shadow: var(--shadow-sm);
}

.user-info-text {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  color: var(--text-color);
  font-weight: 700;
}

.user-openid {
  font-size: 24rpx;
  color: var(--text-light);
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

/* 菜单列表 */
.menu-list {
  background: transparent;
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
}

.menu-section {
  margin-bottom: 20rpx;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.menu-title {
  font-size: 28rpx;
  color: var(--text-light);
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: var(--input-bg);
  font-weight: 600;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.15s;
}

.menu-item:active {
  background: var(--input-bg);
}

.menu-icon {
  margin-right: 20rpx;
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.menu-arrow {
  color: var(--border-color);
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: -2rpx;
}

/* 设置区域 */
.settings {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  margin-bottom: 30rpx; /* 增加底部间距 */
  overflow: hidden;
}

/* 管理员菜单样式 */
.menu-section:last-child .menu-item:last-child {
  border-bottom: none;
}

/* 退出登录按钮样式 */
.settings .menu-item:last-child .menu-text {
  color: var(--danger-color);
}

.avatar-btn {
  display: flex;
  align-items: center;
  padding: 0;
  background: transparent;
  border: none;
  margin-right: 30rpx;
}

.profile-version {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}