.settings-container {
  padding: 24rpx;
  background: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.settings-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 8rpx 0 24rpx 4rpx;
  color: var(--text-color);
}

/* ── 设置分组 ── */
.settings-section {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.settings-header {
  padding: 18rpx 32rpx;
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 600;
  letter-spacing: 2rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: var(--input-bg);
}

/* ── 设置项 ── */
.settings-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.15s;
}
.settings-item:last-child { border-bottom: none; }
.settings-item:active { background: var(--input-bg); }

.settings-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.settings-value {
  font-size: 26rpx;
  color: var(--text-light);
  margin-right: 12rpx;
}

.settings-arrow {
  color: var(--border-color);
  font-size: 28rpx;
}

.settings-action {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.phone-btn {
  margin: 0;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  line-height: 1.6;
  background: var(--primary-color);
  color: #fff;
  border-radius: var(--radius-full);
  font-weight: 500;
  transition: opacity 0.15s;
}
.phone-btn:active { opacity: 0.82; }