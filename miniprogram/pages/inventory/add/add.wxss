.container {
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--background-color);
  min-height: 100vh;
}

/* ── 图片上传 ── */
.image-upload {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.image-preview {
  width: 240rpx;
  height: 240rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  background: var(--input-bg);
}

.preview-image { width: 100%; height: 100%; }

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx dashed #C8C8C8;
  border-radius: var(--radius-md);
}

.upload-plus {
  position: relative;
  width: 52rpx;
  height: 52rpx;
}

.upload-plus::before,
.upload-plus::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 52rpx;
  height: 5rpx;
  background: var(--primary-color);
  border-radius: var(--radius-full);
  transform: translate(-50%, -50%);
}

.upload-plus::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.placeholder-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* ── 表单区块 ── */
.form-section {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
  margin-bottom: 28rpx;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

.form-item {
  margin-bottom: 28rpx;
}
.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.form-label.required::before {
  content: '*';
  color: var(--danger-color);
}

.form-input {
  height: 88rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.form-input:focus { border-color: var(--primary-color); }

.picker {
  height: 88rpx;
  background: var(--input-bg);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}
.picker::after {
  content: '›';
  font-size: 36rpx;
  color: var(--text-light);
  transform: rotate(90deg);
  display: inline-block;
}
.picker.placeholder { color: var(--text-light); }

/* ── 底部固定区域 ── */
.bottom-fixed-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--card-bg);
  box-shadow: 0 -1rpx 0 var(--border-color);
}

.bottom-safe-area { height: 160rpx; }

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background: var(--card-bg);
}

/* ── 按钮 ── */
.form-actions {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.cancel-btn:active { opacity: 0.7; }

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.submit-btn:active { opacity: 0.82; }