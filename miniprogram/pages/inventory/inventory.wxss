.container {
  position: relative;
  height: 100vh;
  background: var(--background-color);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ── 搜索 + 筛选 固定头部 ── */
.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--card-bg);
  padding: 16rpx 24rpx 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.search-box {
  position: relative;
  margin-bottom: 0;
}

.search-input {
  height: 72rpx;
  background: var(--input-bg);
  border-radius: var(--radius-full);
  padding: 0 72rpx 0 40rpx;
  font-size: 28rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid var(--text-light);
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: '';
  position: absolute;
  right: -10rpx;
  bottom: -8rpx;
  width: 14rpx;
  height: 4rpx;
  background: var(--text-light);
  border-radius: var(--radius-full);
  transform: rotate(45deg);
}

/* ── 筛选 Tab ── */
.filter-bar {
  position: fixed;
  top: 100rpx;
  left: 0;
  right: 0;
  z-index: 99;
  display: flex;
  flex-direction: row;
  background: var(--card-bg);
  height: 80rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-top: 0;
}

.filter-item {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: color 0.2s;
}
.filter-item.active {
  color: var(--primary-color);
  font-weight: 700;
}
.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.filter-item .count {
  font-size: 18rpx;
  color: var(--text-light);
  margin-top: 2rpx;
}
.filter-item.active .count { color: var(--primary-color); }

/* ── 列表容器 ── */
.inventory-scroll-container {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.inventory-list {
  flex: 1;
  padding: 16rpx 24rpx;
  padding-top: 204rpx;
  padding-bottom: 220rpx;
  width: 100%;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
  height: 100%;
}

/* ── 滑动删除 ── */
.inventory-item-container {
  margin-bottom: 18rpx;
  width: 100%;
  height: 188rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  display: flex;
  position: relative;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.movable-area {
  height: 188rpx;
  width: calc(100% - 140rpx);
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  z-index: 3;
}

.movable-view {
  width: 750rpx;
  height: 188rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
}

.movable-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  width: 140rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: var(--danger-color);
  border-top-right-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);
}

/* ── 列表项 ── */
.inventory-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
}

.item-image {
  width: 116rpx;
  height: 116rpx;
  min-width: 116rpx;
  margin-right: 20rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--input-bg);
}
.item-image image { width: 100%; height: 100%; }

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-amount {
  display: inline-flex;
  align-items: center;
  max-width: 220rpx;
  min-height: 44rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: var(--radius-full);
  background: rgba(76,175,80,0.1);
  font-size: 24rpx;
  color: var(--primary-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 右侧日期 */
.item-dates-container {
  min-width: 208rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.date-label {
  font-size: 21rpx;
  color: var(--text-light);
  white-space: nowrap;
}

.date-value {
  font-size: 23rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.days-left {
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-full);
  background: rgba(76,175,80,0.1);
  font-size: 22rpx;
  color: var(--primary-color);
  font-weight: 600;
  display: flex;
  align-items: center;
}
.expired {
  color: var(--danger-color) !important;
  font-weight: 600;
}
.expiring-soon {
  color: var(--warning-color) !important;
  font-weight: 600;
}
.days-left.expired { background: rgba(244,67,54,0.1); }
.days-left.expiring-soon { background: rgba(255,152,0,0.12); }

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 8rpx;
  padding: 120rpx 40rpx;
  gap: 24rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.empty-text { font-size: 30rpx; color: var(--text-light); }

.seed-btn {
  min-width: 220rpx;
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: var(--radius-full);
  background: var(--primary-color);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  transition: opacity 0.15s ease;
}
.seed-btn:active { opacity: 0.82; }

/* ── 加载 ── */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #E8E8E8;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-spinner.small { width: 32rpx; height: 32rpx; border-width: 4rpx; }
.loading-text { font-size: 26rpx; color: var(--text-light); }

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more-tip, .no-more-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  color: var(--text-light);
  font-size: 24rpx;
}

/* ── FAB ── */
.add-btn {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  width: 112rpx;
  height: 112rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 200;
  transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
}
.add-btn:active {
  transform: scale(0.93);
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.22);
}

.add-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}

.add-icon::before,
.add-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 44rpx;
  height: 5rpx;
  background: #fff;
  border-radius: var(--radius-full);
  transform: translate(-50%, -50%);
}

.add-icon::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.delete-btn-container { display: none; }