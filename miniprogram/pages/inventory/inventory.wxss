.container {
  position: relative;
  height: 100vh;
  background: var(--background-color);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ── 搜索 + 筛选 固定头部 ── */
.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  padding: 16rpx 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.search-box {
  position: relative;
  margin-bottom: 0;
}

.search-input {
  height: 72rpx;
  background: var(--input-bg);
  border-radius: var(--radius-full);
  padding: 0 72rpx 0 40rpx;
  font-size: 28rpx;
  color: var(--text-color);
  width: 100%;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-light);
  font-size: 32rpx;
}

/* ── 筛选 Tab ── */
.filter-bar {
  display: flex;
  flex-direction: row;
  background: #fff;
  height: 80rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-top: 0;
}

.filter-item {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: color 0.2s;
}
.filter-item.active {
  color: var(--primary-color);
  font-weight: 700;
}
.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.filter-item .count {
  font-size: 18rpx;
  color: var(--text-light);
  margin-top: 2rpx;
}
.filter-item.active .count { color: var(--primary-color); }

/* ── 列表容器 ── */
.inventory-scroll-container {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.inventory-list {
  flex: 1;
  padding: 16rpx 24rpx;
  padding-top: calc(72rpx + 80rpx + 32rpx + 16rpx);
  padding-bottom: 180rpx;
  width: 100%;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
  height: 100%;
}

/* ── 滑动删除 ── */
.inventory-item-container {
  margin-bottom: 16rpx;
  width: 100%;
  height: 176rpx;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  display: flex;
  position: relative;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.movable-area {
  height: 176rpx;
  width: calc(100% - 140rpx);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  z-index: 3;
}

.movable-view {
  width: 750rpx;
  height: 176rpx;
  background: var(--card-bg);
  border-radius: var(--radius-md);
}

.movable-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  width: 140rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: var(--danger-color);
  border-top-right-radius: var(--radius-md);
  border-bottom-right-radius: var(--radius-md);
}

/* ── 列表项 ── */
.inventory-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: var(--card-bg);
  border-radius: var(--radius-md);
}

.item-image {
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  margin-right: 20rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--input-bg);
}
.item-image image { width: 100%; height: 100%; }

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-amount {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 右侧日期 */
.item-dates-container {
  min-width: 192rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.date-label {
  font-size: 20rpx;
  color: var(--text-light);
  white-space: nowrap;
}

.date-value {
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.days-left {
  font-size: 22rpx;
  color: var(--primary-color);
  font-weight: 600;
}
.expired { color: var(--danger-color) !important; font-weight: 600; }
.expiring-soon { color: var(--warning-color) !important; font-weight: 600; }

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 16rpx;
}
.empty-text { font-size: 30rpx; color: var(--text-light); }

/* ── 加载 ── */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #E8E8E8;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-spinner.small { width: 32rpx; height: 32rpx; border-width: 4rpx; }
.loading-text { font-size: 26rpx; color: var(--text-light); }

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more-tip, .no-more-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  color: var(--text-light);
  font-size: 24rpx;
}

/* ── FAB ── */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 104rpx;
  height: 104rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 200;
  transition: transform 0.15s, box-shadow 0.15s;
  line-height: 1;
}
.add-btn:active {
  transform: scale(0.93);
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.22);
}

.delete-btn-container { display: none; }