<view class="tab-bar">
  <view wx:for="{{list}}" wx:key="index" class="tab-bar-item" data-index="{{index}}" bindtap="switchTab">
    <view class="tab-bar-icon-wrap">
      <image class="tab-bar-icon {{selected === index ? 'icon-active' : ''}}" src="{{item.icon}}" mode="aspectFit"></image>
    </view>
    <view class="tab-bar-text {{selected === index ? 'text-active' : ''}}">{{item.text}}</view>
  </view>
</view> 