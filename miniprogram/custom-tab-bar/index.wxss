.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.1);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 48px;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
}

.tab-bar-icon-wrap {
  width: 24px;
  height: 24px;
  margin-bottom: 4px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tab-bar-icon {
  width: 24px;
  height: 24px;
  filter: grayscale(100%) opacity(0.45);
  transition: filter 150ms ease;
}

.tab-bar-text {
  font-size: 12px;
  color: #999999;
  transition: color 150ms ease;
}

.icon-active {
  filter: none;
}

.text-active {
  color: #4CAF50;
  font-weight: 600;
}