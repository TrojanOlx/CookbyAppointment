/**app.wxss**/
.container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  box-sizing: border-box;
  background-color: var(--wc-bg-color);
}

/* 通用样式 */
page {
  --primary-color: #4CAF50;
  --primary-light: #E8F5E9;
  --primary-dark: #388E3C;
  --danger-color: #F44336;
  --danger-light: #FFEBEE;
  --warning-color: #FF9800;
  --warning-light: #FFF3E0;
  --success-color: #4CAF50;
  --text-color: #1A1A1A;
  --text-secondary: #555555;
  --text-light: #999999;
  --background-color: #F5F5F7;
  --card-bg: #FFFFFF;
  --input-bg: #F7F8FA;
  --border-color: #EBEBEB;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.10);
  --shadow-fab: 0 8rpx 24rpx rgba(76,175,80,0.35);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  --wc-bg-color: #ffffff;
  --wc-text-color: #333333;
  --wc-placeholder-color: #999999;
  --wc-holiday-color: #ff4d4f;
  --wc-selected-color: #4CAF50;
  --wc-normal-color: #333333;
  --wc-weekend-color: #333333;
  --wc-dot-color: #4CAF50;
  --wc-solar-color: #fa8c16;

  background-color: var(--background-color);
  color: var(--text-color);
  font-size: 14px;
  line-height: 1.5;
  box-sizing: border-box;
}

/* 公共卡片 */
.g-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* Section 标题：左侧绿色竖条 */
.g-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  padding-left: 20rpx;
  position: relative;
  margin-bottom: 24rpx;
}
.g-section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

/* 通用 FAB 悬浮按钮 */
.g-fab {
  position: fixed;
  right: 40rpx;
  width: 104rpx;
  height: 104rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-fab);
  z-index: 200;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.g-fab:active {
  transform: scale(0.93);
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.25);
}
.g-fab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.g-fab-icon::before,
.g-fab-icon::after {
  content: '';
  position: absolute;
  background: #fff;
  border-radius: 3rpx;
}
.g-fab-icon::before {
  width: 4rpx;
  height: 36rpx;
}
.g-fab-icon::after {
  width: 36rpx;
  height: 4rpx;
}

/* 通用底部固定操作区 */
.g-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--card-bg);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -1rpx 0 var(--border-color);
  z-index: 100;
}

/* 通用按钮 */
.g-btn-primary {
  flex: 1;
  height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.g-btn-primary:active { opacity: 0.82; }

.g-btn-ghost {
  flex: 1;
  height: 88rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.g-btn-ghost:active { opacity: 0.7; }

/* 通用输入框 */
.g-input {
  width: 100%;
  height: 88rpx;
  background: var(--input-bg);
  border-radius: var(--radius-sm);
  border: 2rpx solid transparent;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-color);
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.g-input:focus {
  border-color: var(--primary-color);
}

/* 通用空状态 */
.g-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 20rpx;
}
.g-empty-icon {
  font-size: 80rpx;
  color: #D0D0D0;
  margin-bottom: 8rpx;
}
.g-empty-title {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
.g-empty-sub {
  font-size: 26rpx;
  color: var(--text-light);
  text-align: center;
}

/* 自定义底部TabBar */
.tab-bar-icon {
  font-size: 22px;
  margin-bottom: 4px;
  position: relative;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

/* 提供字体图标颜色 */
.icon-active {
  color: #4CAF50;
}

/* 清除按钮默认样式 */
button {
  background: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  border-radius: 0;
  border: none;
}

button::after {
  border: none;
}

/* 溢出文字省略号 */
.ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 多行文本溢出省略 */
.multi-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 日历组件全局样式 */
.wc-calendar {
  width: 100%;
  background: var(--wc-bg-color);
}

/* 农历文字样式 */
.wc-calendar .wc-lunar {
  font-size: 20rpx;
  color: var(--wc-placeholder-color);
}

/* 节日样式 */
.wc-calendar .wc-festival {
  color: var(--wc-holiday-color);
}

/* 选中日期样式 */
.wc-calendar .wc-selected {
  background-color: var(--wc-selected-color);
  color: #ffffff;
}

/* 今天日期样式 */
.wc-calendar .wc-today {
  color: var(--wc-selected-color);
}

/* 周末样式 */
.wc-calendar .wc-weekend {
  color: var(--wc-weekend-color);
}

/* 节气样式 */
.wc-calendar .wc-solar {
  color: var(--wc-solar-color);
} 
